export EDITOR=vim
export VISUAL=vim
export PAGER=lv

if [[ -z "$LANG" ]]; then
  export LANG='en_US.UTF-8'
fi

#
# Paths
#

# Ensure path arrays do not contain duplicates.
typeset -gU cdpath fpath mailpath path

typeset -gxU path PATH

# project 直下の cheats を読み込むため、.cheats を追加
path=(
  $HOME/.local/bin
  $HOME/google-cloud-sdk/bin
  $HOME/.volta/bin
  ${0:A:h}
  $HOME/Library/pnpm
  /opt/homebrew/bin(N-/)
  /opt/homebrew/sbin(N-/)
  /usr/bin
  /usr/sbin
  /bin
  /sbin
  /usr/local/bin(N-/)
  /usr/local/sbin(N-/)
  /Library/Apple/usr/bin
)

# navi cheats path (requires /opt/homebrew/bin in PATH)
path+=("$(navi info cheats-path 2>/dev/null)" .cheats)
